// ── Alert System ─────────────────────────────────────────────────────────────

model AlertRule {
  id                 Int           @id @default(autoincrement())
  name               String        @db.VarChar(150)
  metric_id          Int
  condition_operator String        @db.VarChar(20)
  threshold_value    Decimal       @db.Decimal(10, 2)
  scope              AudienceScope
  is_active          Boolean       @default(true)
  created_by         Int
  created_at         DateTime      @default(now()) @db.DateTime(0)

  metric              MetricDefinition         @relation(fields: [metric_id], references: [id], onDelete: Cascade)
  creator             User                     @relation(fields: [created_by], references: [id], onDelete: Cascade)
  alert_notifications AlertNotificationQueue[]

  @@map("alert_rules")
}

model UserAlertPreferences {
  id           Int      @id @default(autoincrement())
  user_id      Int      @unique
  frequency    String   @db.VarChar(50)
  batch_alerts Boolean  @default(true)
  timezone     String   @db.VarChar(100)
  updated_at   DateTime @default(now()) @updatedAt @db.DateTime(0)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_alert_preferences")
}

model AlertNotificationQueue {
  id         Int           @id @default(autoincrement())
  rule_id    Int
  user_id    Int
  message    String        @db.Text
  priority   AlertPriority @default(NORMAL)
  is_sent    Boolean       @default(false)
  created_at DateTime      @default(now()) @db.DateTime(0)
  sent_at    DateTime?     @db.DateTime(0)

  rule AlertRule @relation(fields: [rule_id], references: [id], onDelete: Cascade)
  user User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([is_sent, created_at])
  @@map("alert_notification_queue")
}

