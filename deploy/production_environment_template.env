# ===============================================
# QTIP PRODUCTION ENVIRONMENT CONFIGURATION
# ===============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ===============================================
# APPLICATION CONFIGURATION
# ===============================================
NODE_ENV=production
PORT=3000
APP_NAME=QTIP
APP_VERSION=1.0.0

# ===============================================
# DATABASE CONFIGURATION
# ===============================================
# Primary MySQL/MariaDB connection settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=qtip_user
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD_HERE
DB_NAME=qtip_production
DB_CONNECTION_LIMIT=20

# ===============================================
# SECONDARY DATABASE CONFIGURATION (Optional)
# ===============================================
# Secondary MySQL/MariaDB connection settings (for analytics, reporting, etc.)
DB2_HOST=localhost
DB2_PORT=3306
DB2_USER=qtip_analytics_user
DB2_PASSWORD=YOUR_SECURE_SECONDARY_DATABASE_PASSWORD_HERE
DB2_NAME=qtip_analytics
DB2_CONNECTION_LIMIT=10

# ===============================================
# DATABASE SELECTION
# ===============================================
# Specify which database to use for different operations
# Options: 'primary', 'secondary', or 'both'
DEFAULT_DB=primary
ANALYTICS_DB=secondary
REPORTING_DB=secondary

# ===============================================
# SECURITY CONFIGURATION
# ===============================================
# JWT Configuration - MUST be changed for production
JWT_SECRET=YOUR_SUPER_SECURE_JWT_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=YOUR_SUPER_SECURE_REFRESH_TOKEN_SECRET_HERE_MINIMUM_32_CHARACTERS
REFRESH_TOKEN_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ===============================================
# CORS CONFIGURATION
# ===============================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com

# ===============================================
# FILE UPLOAD CONFIGURATION
# ===============================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# ===============================================
# EMAIL CONFIGURATION
# ===============================================
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@your-domain.com
SMTP_PASSWORD=YOUR_EMAIL_PASSWORD_HERE
SMTP_SECURE=true

# ===============================================
# LOGGING CONFIGURATION
# ===============================================
LOG_LEVEL=info
LOG_FILE=./logs/application.log
LOG_MAX_FILES=30
LOG_MAX_SIZE=10485760

# ===============================================
# MONITORING & HEALTH CHECKS
# ===============================================
HEALTH_CHECK_INTERVAL=30000
ENABLE_METRICS=true

# ===============================================
# REDIS CONFIGURATION (if using for caching)
# ===============================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ===============================================
# SSL/TLS CONFIGURATION (for HTTPS)
# ===============================================
# SSL_KEY_PATH=/path/to/private.key
# SSL_CERT_PATH=/path/to/certificate.crt
# SSL_CA_PATH=/path/to/ca-bundle.crt 