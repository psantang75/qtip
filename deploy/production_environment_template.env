# ===============================================
# QTIP PRODUCTION ENVIRONMENT CONFIGURATION
# ===============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ===============================================
# APPLICATION CONFIGURATION
# ===============================================
NODE_ENV=production
PORT=3000
APP_NAME=QTIP
APP_VERSION=1.0.0

# ===============================================
# PRIMARY DATABASE (Q-TIP)
# ===============================================
# Q-Tip's own MySQL/MariaDB instance. Read/write.
DB_HOST=localhost
DB_PORT=3306
DB_USER=qtip_user
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD_HERE
DB_NAME=qtip_production
DB_CONNECTION_LIMIT=20

# ===============================================
# PHONE SYSTEM DATABASE (READ-ONLY CONSUMER)
# ===============================================
# External phone-system DB. Q-Tip queries this for call transcripts and audio
# URLs and snapshots the relevant rows into its own tables when a call is
# reviewed. Use a read-only MySQL user.
PHONE_DB_HOST=YOUR_PHONE_DB_HOST
PHONE_DB_PORT=3306
PHONE_DB_USER=qtip_phone_ro
PHONE_DB_PASSWORD=YOUR_SECURE_PHONE_DB_PASSWORD_HERE
PHONE_DB_NAME=PhoneSystem
PHONE_DB_CONNECTION_LIMIT=10

# ===============================================
# CRM DATABASE (PHASE 2, READ-ONLY CONSUMER)
# ===============================================
# External CRM DB used to attach tickets to QA submissions. Leave PASSWORD blank
# to disable; the CRM pool is only created when every required value is set.
CRM_DB_HOST=
CRM_DB_PORT=3306
CRM_DB_USER=qtip_crm_ro
CRM_DB_PASSWORD=
CRM_DB_NAME=
CRM_DB_CONNECTION_LIMIT=5

# ===============================================
# AI PROVIDERS
# ===============================================
# Leave an API key blank to disable that provider. Health checks will report
# 'not_configured' rather than failing.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_TIMEOUT_MS=30000
ANTHROPIC_MAX_RETRIES=2

# ===============================================
# SECURITY CONFIGURATION
# ===============================================
# JWT Configuration - MUST be changed for production
JWT_SECRET=YOUR_SUPER_SECURE_JWT_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=YOUR_SUPER_SECURE_REFRESH_TOKEN_SECRET_HERE_MINIMUM_32_CHARACTERS
REFRESH_TOKEN_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ===============================================
# CORS CONFIGURATION
# ===============================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com

# ===============================================
# FILE UPLOAD CONFIGURATION
# ===============================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# ===============================================
# EMAIL CONFIGURATION
# ===============================================
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@your-domain.com
SMTP_PASSWORD=YOUR_EMAIL_PASSWORD_HERE
SMTP_SECURE=true

# ===============================================
# LOGGING CONFIGURATION
# ===============================================
LOG_LEVEL=info
LOG_FILE=./logs/application.log
LOG_MAX_FILES=30
LOG_MAX_SIZE=10485760

# ===============================================
# MONITORING & HEALTH CHECKS
# ===============================================
HEALTH_CHECK_INTERVAL=30000
ENABLE_METRICS=true

# ===============================================
# REDIS CONFIGURATION (if using for caching)
# ===============================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ===============================================
# SSL/TLS CONFIGURATION (for HTTPS)
# ===============================================
# SSL_KEY_PATH=/path/to/private.key
# SSL_CERT_PATH=/path/to/certificate.crt
# SSL_CA_PATH=/path/to/ca-bundle.crt
