{
    // ...existing code...
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node-terminal",
            "name": "Run Script: dev:backend",
            "request": "launch",
            "command": "npm run dev:backend",
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Backend",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["ts-node", "src/index.ts"],
            "cwd": "${workspaceFolder}/backend",
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ],
            "env": {
                "NODE_ENV": "development"
            }
        }
    ]
}